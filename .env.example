# ========================================
# SlimCheck API 环境变量配置示例
# ========================================

# ============== LLM 配置 ==============
# 火山引擎豆包示例
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=doubao-seed-2.0-pro

# ============== 服务配置 ==============
HOST=0.0.0.0
PORT=8083
WORKERS=2
LOG_LEVEL=INFO
DEBUG=false

# ============== CORS 配置 ==============
# 生产环境请配置具体域名，例如：https://yourdomain.com,http://localhost:3000
CORS_ORIGINS=*

# ============== 并发控制 ==============
# 最大并发请求数（每个请求会占用一个 LLM 连接）
MAX_CONCURRENT_REQUESTS=10

# 单请求超时时间（秒）
REQUEST_TIMEOUT_SECONDS=120

# 已完成请求保留时间（小时）
COMPLETED_REQUEST_TTL_HOURS=1

# ============== 认证配置 ==============
# 是否启用 API Key 认证（默认关闭）
API_KEY_ENABLED=false
# API_KEY=your_secret_api_key_here

# ============== 限流配置 ==============
RATE_LIMIT_ENABLED=false
# 每分钟最多请求数
RATE_LIMIT_PER_MINUTE=30

# ============== 数据存储 ==============
# 存储类型: json / mysql
STORAGE_TYPE=mysql
DATA_DIR=./data
USERS_DIR=./data/users
LOGS_DIR=./data/logs

# ============== MySQL 数据库 ==============
DB_HOST=127.0.0.1
DB_PORT=3006
DB_USER=root
DB_PASSWORD=123456
DB_NAME=db_slimcheck
DB_CHARSET=utf8mb4
